# ── Models ────────────────────────────────────────────────────────────────────
# Ollama model for parsing Strivee accessibility text into programming blocks
OLLAMA_TEXT_MODEL=qwen3:8b
# Optional fallback when primary returns zero blocks — leave empty to disable
# OLLAMA_FALLBACK_TEXT_MODEL=qwen3:8b
# Ollama model for BTWB text formatting (lighter model is fine here)
OLLAMA_FORMAT_MODEL=qwen3:8b

# ── BTWB credentials ──────────────────────────────────────────────────────────
BTWB_EMAIL=your@email.com
BTWB_PASSWORD=yourpassword
# Your personal track ID — visible in the calendar URL when you click a day: ?t=156552
BTWB_TRACK_ID=156552

# ── ADB / capture ─────────────────────────────────────────────────────────────
# ADB device serial — leave empty if only one device is connected
# ANDROID_SERIAL=
# Maximum scrolls per day (capture stops automatically when content ends)
MAX_SCROLLS=10
# Y-coordinate (pixels) of the Strivee day-tab strip — used for week/day navigation taps.
# Tune once per device. 500 works well on a 1080×2400 screen.
# Set to 0 to fall back to a screen-fraction estimate.
# DAY_TAB_Y=500

# ── Block filtering ───────────────────────────────────────────────────────────
# Block names to exclude (case-insensitive substring match, comma-separated)
EXCLUDED_BLOCKS="Hebdomadaire,GROUPE WHATS APP EMF,Warm-up,Swim Workout,Sport simulation"
