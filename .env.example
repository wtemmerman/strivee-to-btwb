OLLAMA_MODEL=qwen3vl:8b
OLLAMA_FALLBACK_MODEL=qwen2.5vl:7B
BTWB_EMAIL=your@email.com
BTWB_PASSWORD=yourpassword
# Your personal track ID — visible in the calendar URL when you click a day: ?t=156552
BTWB_TRACK_ID=156552
# ADB device serial — leave empty if only one device is connected
# ANDROID_SERIAL=
# How many scrolls per day (stops automatically when content ends)
MAX_SCROLLS=10
# Fraction of screen scrolled per swipe — smaller = more overlap, fewer missed blocks
SCROLL_DISTANCE=0.42
# Pixels to crop from each frame before vision analysis
# Removes the Strivee header (day tabs) and bottom nav bar that appear in every frame
# Tune by checking a saved capture in captures/ — measure the header height in pixels
# CAPTURE_CROP_TOP=550
# CAPTURE_CROP_BOTTOM=250
# Block names to exclude (case-insensitive prefix match, comma-separated)
EXCLUDED_BLOCKS="Hebdomadaire,GROUPE WHATS APP EMF,Warm-up"
# Optional: use a saved screenshot instead of live ADB capture (for testing)
# FIXTURE_IMAGE_PATH=fixtures/sample_strivee.png
